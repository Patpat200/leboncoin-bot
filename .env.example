# Token du bot (Discord Developer Portal > Applications > ton bot > Bot > Token)
DISCORD_TOKEN=

# Client ID de l'application (Developer Portal > General Information)
CLIENT_ID=

# ID du serveur Discord où tu veux deployer les commandes (clic droit sur le serveur > Copier l'ID)
# Active le mode developpeur dans Discord (Parametres > Avance) pour avoir cette option.
GUILD_ID=

# Intervalle entre chaque verification des annonces, en minutes
POLL_INTERVAL_MINUTES=5

# Rayon par defaut (en km) quand un code postal est fourni sans rayon explicite
DEFAULT_RADIUS_KM=20

# Tous les combien d'heures on rafraichit le prix de reference Amazon
# (ignore pour les watches avec un prix_reference fixe manuellement)
REF_PRICE_REFRESH_HOURS=24

# Seuil de reduction (en %) par rapport au prix de reference pour marquer
# une annonce comme "bonne affaire" (badge fire + couleur verte)
DEAL_THRESHOLD_PERCENT=25

# Port de l'interface web locale (dashboard)
WEB_PORT=3000

# Optionnel : si Leboncoin bloque les requetes (DataDome), colle ici la valeur
# du cookie recupere depuis ton navigateur (devtools > Network > une requete
# vers api.leboncoin.fr > onglet Headers > Cookie). A renouveler si ca expire.
LBC_COOKIE=
